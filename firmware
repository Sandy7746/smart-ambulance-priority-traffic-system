#include <WiFi.h>
#include <HTTPClient.h>
#include <ArduinoJson.h>
#include <math.h>

// WiFi credentials
const char* ssid = "Sandy";
const char* password = "99999999";

// Firebase configuration
const String FIREBASE_URL = "https://ambulance-15b39-default-rtdb.asia-southeast1.firebasedatabase.app/";

// Junction center point
const double JUNCTION_LAT = 15.538500;
const double JUNCTION_LON = 79.971500;

// Simplified TrafficSignal structure
struct TrafficSignal {
  const char* roadName;
  int redPin, greenPin, bluePin;
};

TrafficSignal signals[4] = {
  {"north", 25, 26, 27},
  {"east",  32, 33, 34},
  {"south", 15, 2, 4},
  {"west",  19, 21, 22}
};

// Ambulance structure with emergency scale
struct Ambulance {
  String id;
  double lat, lon;
  const char* road;
  double distance;
  int emergencyScale;
  bool active;
};

Ambulance ambulances[2];
int ambulanceCount = 0;

// System variables
const char* currentGreenRoad = "north";
bool priorityMode = false;
unsigned long stateStartTime = 0;
unsigned long systemStartTime = 0;
bool initialTrafficCycleCompleted = false;

// Priority queue variables
bool servingPriorityQueue = false;
Ambulance* priorityQueue[2];
int queueSize = 0;
int currentQueueIndex = 0;

// Timing settings
const unsigned long GREEN_TIME = 5000;
const unsigned long YELLOW_TIME = 2000;
const unsigned long ALL_RED_TIME = 1000;
const unsigned long INITIAL_TRAFFIC_TIME = 10000;
const unsigned long PRIORITY_DURATION = 5000; // 5 seconds per ambulance
const unsigned long AMBULANCE_UPDATE_INTERVAL = 15000; // 15 seconds

// Traffic cycle states
enum TrafficState { GREEN, YELLOW, ALL_RED };
TrafficState currentTrafficState = GREEN;

// Timing variables
unsigned long lastUpdateTime = 0;
unsigned long lastCycleTime = 0;
unsigned long lastBlinkTime = 0;
unsigned long priorityStartTime = 0;
bool blinkState = false;

// Detection ranges
const double CRITICAL_RANGE = 100.0; // 100m for emergency 1-2
const double NORMAL_RANGE = 50.0;    // 50m for emergency 3-5

void setup() {
  Serial.begin(115200);
  
  // Initialize all RGB LEDs
  for(int i = 0; i < 4; i++) {
    pinMode(signals[i].redPin, OUTPUT);
    pinMode(signals[i].greenPin, OUTPUT);
    pinMode(signals[i].bluePin, OUTPUT);
    setRGBColor(signals[i].roadName, "off");
  }
  
  // Start with north road green
  setRGBColor("north", "green");
  currentGreenRoad = "north";
  stateStartTime = millis();
  systemStartTime = millis();
  
  // Connect to WiFi
  connectToWiFi();
  
  Serial.println("\n🚦 4-ROAD JUNCTION WITH EMERGENCY SCALE");
  Serial.println("🚑 Emergency Scale: 1(Most Critical) to 5(Least Critical)");
  Serial.println("🎯 Detection Ranges: 100m (Emergency 1-2), 50m (Emergency 3-5)");
  Serial.println("🔄 Database Updates: Every 15 seconds");
  Serial.println("⏰ Priority Duration: 5 seconds per ambulance");
  Serial.println("📋 Sequential Priority: Serves multiple critical ambulances");
  Serial.println("==========================================");
}

void connectToWiFi() {
  WiFi.begin(ssid, password);
  Serial.print("Connecting to WiFi");
  unsigned long startTime = millis();
  while (WiFi.status() != WL_CONNECTED && millis() - startTime < 15000) {
    delay(500);
    Serial.print(".");
  }
  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\n✅ Connected to WiFi!");
  } else {
    Serial.println("\n❌ WiFi Failed!");
  }
}

void loop() {
  unsigned long currentMillis = millis();
  
  // Handle blinking
  if (currentMillis - lastBlinkTime >= 500) {
    lastBlinkTime = currentMillis;
    blinkState = !blinkState;
    handleBlinking();
  }
  
  // Initial traffic cycle
  if (!initialTrafficCycleCompleted) {
    if (currentMillis - systemStartTime < INITIAL_TRAFFIC_TIME) {
      handleNormalTrafficCycle(currentMillis);
    } else {
      initialTrafficCycleCompleted = true;
      Serial.println("✅ Initial traffic cycle completed. Starting ambulance simulation.");
      updateAmbulancePositions();
      updateFirebase();
      lastUpdateTime = currentMillis;
    }
    delay(100);
    return;
  }
  
  // Main operation - Check for updates every 15 seconds
  if (currentMillis - lastUpdateTime >= AMBULANCE_UPDATE_INTERVAL) {
    lastUpdateTime = currentMillis;
    Serial.println("\n🔄 READING DATA FROM FIREBASE (15s Update)...");
    updateAmbulancePositions();
    updateFirebase();
    checkAmbulanceDetection(currentMillis);
    Serial.println("✅ Database update completed. Next update in 15 seconds.");
    Serial.println("==========================================");
  }
  
  // Priority mode timer - Handle sequential priority
  if (priorityMode) {
    unsigned long priorityDuration = currentMillis - priorityStartTime;
    if (priorityDuration >= PRIORITY_DURATION) {
      // Current priority finished, check if there's next in queue
      if (servingPriorityQueue && currentQueueIndex < queueSize - 1) {
        // Move to next ambulance in queue
        currentQueueIndex++;
        startNextPriority(currentMillis);
      } else {
        // All priorities completed
        Serial.println("✅ All priority ambulances served. Returning to normal cycle.");
        servingPriorityQueue = false;
        priorityMode = false;
        stateStartTime = currentMillis;
        currentTrafficState = GREEN;
        applyNormalTrafficLights();
      }
    }
  }
  
  // Traffic signal control - Only in normal mode
  if (currentMillis - lastCycleTime >= 1000 && !priorityMode && !servingPriorityQueue) {
    lastCycleTime = currentMillis;
    handleNormalTrafficCycle(currentMillis);
  }
  
  // Print status - Show time until next update
  static unsigned long lastPrintTime = 0;
  if (currentMillis - lastPrintTime >= 3000) {
    lastPrintTime = currentMillis;
    printSystemStatus(currentMillis);
  }
  
  delay(100);
}

void handleBlinking() {
  if (priorityMode) {
    // PRIORITY MODE: Blinking GREEN for ambulance road
    if (blinkState) {
      setRGBColor(currentGreenRoad, "green");
    } else {
      setRGBColor(currentGreenRoad, "off");
    }
    // Other roads stay RED (no blink)
    for(int i = 0; i < 4; i++) {
      if(strcmp(signals[i].roadName, currentGreenRoad) != 0) {
        setRGBColor(signals[i].roadName, "red");
      }
    }
  } else {
    // NORMAL MODE: Apply current traffic state (no blinking)
    applyNormalTrafficLights();
  }
}

void applyNormalTrafficLights() {
  for(int i = 0; i < 4; i++) {
    if(strcmp(signals[i].roadName, currentGreenRoad) == 0) {
      if(currentTrafficState == GREEN) {
        setRGBColor(signals[i].roadName, "green");
      } else if(currentTrafficState == YELLOW) {
        setRGBColor(signals[i].roadName, "yellow");
      } else { // ALL_RED
        setRGBColor(signals[i].roadName, "red");
      }
    } else {
      // Other roads are always RED in normal cycle
      setRGBColor(signals[i].roadName, "red");
    }
  }
}

void setRGBColor(const char* road, const char* color) {
  for(int i = 0; i < 4; i++) {
    if(strcmp(signals[i].roadName, road) == 0) {
      // Turn off all colors first
      digitalWrite(signals[i].redPin, LOW);
      digitalWrite(signals[i].greenPin, LOW);
      digitalWrite(signals[i].bluePin, LOW);
      
      // Set the required color
      if(strcmp(color, "red") == 0) {
        digitalWrite(signals[i].redPin, HIGH);
      } else if(strcmp(color, "green") == 0) {
        digitalWrite(signals[i].greenPin, HIGH);
      } else if(strcmp(color, "yellow") == 0) {
        // RED + GREEN = YELLOW
        digitalWrite(signals[i].redPin, HIGH);
        digitalWrite(signals[i].greenPin, HIGH);
      } else if(strcmp(color, "off") == 0) {
        // All pins already LOW
      }
      return;
    }
  }
}

// NEW: Sequential priority system for multiple ambulances
void checkAmbulanceDetection(unsigned long currentMillis) {
  // Calculate distances for all ambulances
  for(int i = 0; i < ambulanceCount; i++) {
    ambulances[i].distance = calculateDistance(JUNCTION_LAT, JUNCTION_LON, 
                                              ambulances[i].lat, ambulances[i].lon);
  }
  
  // If not currently serving priority queue, find all critical ambulances
  if (!servingPriorityQueue && !priorityMode) {
    findCriticalAmbulances();
    
    if (queueSize > 0) {
      servingPriorityQueue = true;
      currentQueueIndex = 0;
      startNextPriority(currentMillis);
    } else {
      Serial.println("📊 No ambulances in detection range. Current status:");
      for(int i = 0; i < ambulanceCount; i++) {
        double maxRange = (ambulances[i].emergencyScale <= 2) ? CRITICAL_RANGE : NORMAL_RANGE;
        Serial.println("   " + ambulances[i].id + " | Road: " + String(ambulances[i].road) + 
                      " | Dist: " + String(ambulances[i].distance, 1) + "m" +
                      " | Emerg: " + String(ambulances[i].emergencyScale) +
                      " | Range: " + String(maxRange, 0) + "m");
      }
    }
  }
}

// NEW: Find all critical ambulances and create priority queue
void findCriticalAmbulances() {
  queueSize = 0;
  
  Serial.println("🔍 Scanning for ambulances in range:");
  
  // Find all ambulances within their appropriate ranges
  for(int i = 0; i < ambulanceCount; i++) {
    if(ambulances[i].active) {
      double maxRange = (ambulances[i].emergencyScale <= 2) ? CRITICAL_RANGE : NORMAL_RANGE;
      
      if(ambulances[i].distance <= maxRange) {
        // Add to priority queue
        priorityQueue[queueSize] = &ambulances[i];
        queueSize++;
        Serial.println("   ✅ " + ambulances[i].id + " added to queue (Within " + String(maxRange, 0) + "m)");
        
        if(queueSize >= 2) break; // Max 2 in queue
      } else {
        Serial.println("   ❌ " + ambulances[i].id + " out of range (" + 
                      String(ambulances[i].distance, 1) + "m > " + String(maxRange, 0) + "m)");
      }
    }
  }
  
  // Sort queue by priority score (lowest first = highest priority)
  if(queueSize > 1) {
    Serial.println("📊 Sorting priority queue...");
    for(int i = 0; i < queueSize - 1; i++) {
      for(int j = i + 1; j < queueSize; j++) {
        int scoreI = calculatePriorityScore(priorityQueue[i]);
        int scoreJ = calculatePriorityScore(priorityQueue[j]);
        
        if(scoreJ < scoreI) {
          Ambulance* temp = priorityQueue[i];
          priorityQueue[i] = priorityQueue[j];
          priorityQueue[j] = temp;
        }
      }
    }
  }
  
  if(queueSize > 0) {
    Serial.println("📋 PRIORITY QUEUE CREATED (" + String(queueSize) + " ambulances):");
    for(int i = 0; i < queueSize; i++) {
      int score = calculatePriorityScore(priorityQueue[i]);
      Serial.println("   " + String(i+1) + ". " + priorityQueue[i]->id + 
                    " | Road: " + String(priorityQueue[i]->road) +
                    " | Emergency: " + String(priorityQueue[i]->emergencyScale) +
                    " | Distance: " + String(priorityQueue[i]->distance, 1) + "m" +
                    " | Score: " + String(score));
    }
  } else {
    Serial.println("❌ No ambulances in detection range");
  }
}

// NEW: Calculate priority score for an ambulance
int calculatePriorityScore(Ambulance* amb) {
  double maxRange = (amb->emergencyScale <= 2) ? CRITICAL_RANGE : NORMAL_RANGE;
  int emergencyScore = amb->emergencyScale * 7;
  int distanceScore = (int)(amb->distance / maxRange * 3);
  return emergencyScore + distanceScore;
}

// NEW: Start priority for next ambulance in queue
void startNextPriority(unsigned long currentMillis) {
  if (currentQueueIndex < queueSize) {
    Ambulance* currentAmbulance = priorityQueue[currentQueueIndex];
    
    Serial.println("🚑 🚑 🚑 ACTIVATING PRIORITY " + String(currentQueueIndex + 1) + " of " + String(queueSize));
    Serial.println("💚 Blinking GREEN for " + String(currentAmbulance->road) + " road");
    
    // Set all signals to red first for safety
    for(int i = 0; i < 4; i++) {
      setRGBColor(signals[i].roadName, "red");
    }
    
    // Set ambulance road and activate priority
    currentGreenRoad = currentAmbulance->road;
    priorityMode = true;
    priorityStartTime = currentMillis;
    blinkState = true;
    
    // Print ambulance details
    Serial.println("📋 AMBULANCE " + String(currentQueueIndex + 1) + " DETAILS:");
    Serial.println("   ID: " + currentAmbulance->id);
    Serial.println("   Road: " + String(currentAmbulance->road));
    Serial.println("   Distance: " + String(currentAmbulance->distance, 1) + "m");
    Serial.println("   Emergency Scale: " + String(currentAmbulance->emergencyScale) + " (1=Most Critical)");
    Serial.println("   Priority: " + String(currentQueueIndex + 1) + " of " + String(queueSize));
    Serial.println("   Duration: 5 seconds");
    Serial.println("------------------------------------------");
  }
}

void handleNormalTrafficCycle(unsigned long currentMillis) {
  unsigned long stateTime = currentMillis - stateStartTime;
  
  switch(currentTrafficState) {
    case GREEN:
      if (stateTime >= GREEN_TIME) {
        // GREEN → RED (direct, no yellow)
        for(int i = 0; i < 4; i++) {
          setRGBColor(signals[i].roadName, "red");
        }
        currentTrafficState = ALL_RED;
        stateStartTime = currentMillis;
        Serial.println("🔴 ALL RED (Transition)");
      }
      break;
      
    case ALL_RED:
      if (stateTime >= ALL_RED_TIME) {
        // RED → YELLOW (get ready for next road)
        const char* nextRoad = getNextRoad(currentGreenRoad);
        setRGBColor(nextRoad, "yellow");
        currentGreenRoad = nextRoad;
        currentTrafficState = YELLOW;
        stateStartTime = currentMillis;
        Serial.println("🟡 YELLOW for " + String(currentGreenRoad) + " (Get Ready)");
      }
      break;
      
    case YELLOW:
      if (stateTime >= YELLOW_TIME) {
        // YELLOW → GREEN (go)
        setRGBColor(currentGreenRoad, "green");
        currentTrafficState = GREEN;
        stateStartTime = currentMillis;
        Serial.println("🟢 GREEN for " + String(currentGreenRoad) + " (Go)");
      }
      break;
  }
}

void updateAmbulancePositions() {
  // Randomly decide how many ambulances (0, 1, or 2)
  ambulanceCount = random(0, 3);
  
  // Available roads for assignment
  const char* availableRoads[] = {"north", "east", "south", "west"};
  
  // Shuffle roads randomly
  for(int i = 0; i < 4; i++) {
    int randomIndex = random(0, 4);
    const char* temp = availableRoads[i];
    availableRoads[i] = availableRoads[randomIndex];
    availableRoads[randomIndex] = temp;
  }
  
  for(int i = 0; i < ambulanceCount; i++) {
    String ambId = "AMB" + String(i+1);
    const char* road = availableRoads[i];
    
    // Generate random emergency scale (1-5, where 1 is most critical)
    int emergencyScale = random(1, 6);
    
    // Generate coordinates with different distance ranges
    double randomLat, randomLon;
    
    // Create more realistic distance distribution
    int distanceType = random(0, 3); // 0: close, 1: medium, 2: far
    if (distanceType == 0) {
      // Close range (0-30m)
      randomLat = JUNCTION_LAT + (random(-30, 30) / 100000.0); 
      randomLon = JUNCTION_LON + (random(-30, 30) / 100000.0);
    } else if (distanceType == 1) {
      // Medium range (30-70m)
      randomLat = JUNCTION_LAT + (random(-70, 70) / 100000.0);
      randomLon = JUNCTION_LON + (random(-70, 70) / 100000.0);
    } else {
      // Far range (70-150m)
      randomLat = JUNCTION_LAT + (random(-150, 150) / 100000.0);
      randomLon = JUNCTION_LON + (random(-150, 150) / 100000.0);
    }
    
    ambulances[i] = {ambId, randomLat, randomLon, road, 0.0, emergencyScale, true};
  }
  
  if (ambulanceCount > 0) {
    Serial.println("🔄 Generated " + String(ambulanceCount) + " ambulances:");
    for(int i = 0; i < ambulanceCount; i++) {
      Serial.println("   " + ambulances[i].id + " → Road: " + String(ambulances[i].road) + 
                    " | Emergency: " + String(ambulances[i].emergencyScale) + 
                    " (1=Most Critical)");
    }
  } else {
    Serial.println("🔄 No ambulances generated in this cycle");
  }
}

void printSystemStatus(unsigned long currentMillis) {
  unsigned long timeUntilNextUpdate = AMBULANCE_UPDATE_INTERVAL - (currentMillis - lastUpdateTime);
  
  Serial.print("⏰ Mode: ");
  if (servingPriorityQueue) {
    Serial.print("PRIORITY_QUEUE");
    Serial.print(" (" + String(currentQueueIndex + 1) + "/" + String(queueSize) + ")");
  } else {
    Serial.print(priorityMode ? "PRIORITY" : "NORMAL");
  }
  Serial.print(" | Green: ");
  Serial.print(currentGreenRoad);
  Serial.print(" | Ambulances: ");
  Serial.print(ambulanceCount);
  Serial.print(" | Next update in: ");
  Serial.print(timeUntilNextUpdate / 1000);
  Serial.println("s");
  
  if (priorityMode) {
    unsigned long priorityRemaining = PRIORITY_DURATION - (currentMillis - priorityStartTime);
    Serial.print("   🚑 Priority " + String(currentQueueIndex + 1) + " of " + String(queueSize) + ": ");
    Serial.print(priorityRemaining / 1000);
    Serial.println("s remaining");
  }
}

const char* getNextRoad(const char* currentRoad) {
  if (strcmp(currentRoad, "north") == 0) return "east";
  if (strcmp(currentRoad, "east") == 0) return "south";
  if (strcmp(currentRoad, "south") == 0) return "west";
  if (strcmp(currentRoad, "west") == 0) return "north";
  return "north";
}

void updateFirebase() {
  if(WiFi.status() != WL_CONNECTED) {
    connectToWiFi();
    if(WiFi.status() != WL_CONNECTED) {
      Serial.println("❌ WiFi not connected. Skipping Firebase update.");
      return;
    }
  }
  
  HTTPClient http;
  
  // Clear previous ambulance data
  String clearUrl = FIREBASE_URL + "ambulances.json";
  http.begin(clearUrl);
  http.addHeader("Content-Type", "application/json");
  int clearResponse = http.PUT("{}");
  http.end();
  
  // Update active ambulances
  for(int i = 0; i < ambulanceCount; i++) {
    String path = "ambulances/amb" + String(i+1) + ".json";
    String url = FIREBASE_URL + path;
    
    http.begin(url);
    http.addHeader("Content-Type", "application/json");
    
    String jsonData = "{" +
      String("\"id\":\"") + ambulances[i].id + "\"," +
      String("\"lat\":") + String(ambulances[i].lat, 6) + "," +
      String("\"lon\":") + String(ambulances[i].lon, 6) + "," +
      String("\"road\":\"") + ambulances[i].road + "\"," +
      String("\"distance\":") + String(ambulances[i].distance, 2) + "," +
      String("\"emergencyScale\":") + String(ambulances[i].emergencyScale) + "," +
      String("\"timestamp\":") + String(millis()) + "," +
      String("\"active\":true") +
    "}";
    
    int responseCode = http.PUT(jsonData);
    http.end();
  }
  
  // Update traffic signal states
  updateTrafficSignalStates();
  
  Serial.println("✅ Firebase updated successfully with current data");
}

void updateTrafficSignalStates() {
  HTTPClient http;
  
  // Find which ambulance has priority
  String activeAmbulanceId = "";
  if(servingPriorityQueue && currentQueueIndex < queueSize) {
    activeAmbulanceId = priorityQueue[currentQueueIndex]->id;
  }
  
  // Update all 4 traffic signals
  for(int i = 0; i < 4; i++) {
    String path = "traffic_signals/" + String(signals[i].roadName) + ".json";
    String url = FIREBASE_URL + path;
    
    http.begin(url);
    http.addHeader("Content-Type", "application/json");
    
    String state = (strcmp(signals[i].roadName, currentGreenRoad) == 0) ? "green" : "red";
    String activeAmb = (strcmp(signals[i].roadName, currentGreenRoad) == 0) ? activeAmbulanceId : "";
    
    String jsonData = "{" +
      String("\"state\":\"") + state + "\"," +
      String("\"active_ambulance\":\"") + activeAmb + "\"," +
      String("\"priority_mode\":") + (priorityMode ? "true" : "false") +
    "}";
    
    http.PATCH(jsonData);
    http.end();
  }
}

double calculateDistance(double lat1, double lon1, double lat2, double lon2) {
  const double R = 6371000;
  double dLat = (lat2 - lat1) * M_PI / 180.0;
  double dLon = (lon2 - lon1) * M_PI / 180.0;
  
  double a = sin(dLat/2) * sin(dLat/2) +
             cos(lat1 * M_PI / 180.0) * cos(lat2 * M_PI / 180.0) *
             sin(dLon/2) * sin(dLon/2);
  
  double c = 2 * atan2(sqrt(a), sqrt(1-a));
  return R * c;
}
